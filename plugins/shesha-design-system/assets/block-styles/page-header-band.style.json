{
  "$overlay": "page-header-band",
  "$note": "Neutral structural channels only. Brand/accent colour (orange/green) is NOT here — it comes from the live app theme. Button fill = app-theme primary (set on buttonType, not via overlay). Status pill colours come from the reference list. Heading/breadcrumb greys below are structural-neutral text greys, not brand.",
  "targets": {
    "pageHeaderBand": {
      "desktop": {
        "background": { "type": "color", "color": "#ffffff" },
        "border": {
          "hideBorder": false,
          "radiusType": "all",
          "borderType": "custom",
          "border": {
            "all": { "style": "none" },
            "top": {},
            "left": {},
            "right": {},
            "bottom": { "width": 1, "color": "#f0f0f0", "style": "solid" }
          },
          "radius": { "all": 0 }
        },
        "stylingBox": "{\"paddingTop\":\"20\",\"paddingBottom\":\"20\",\"paddingLeft\":\"24\",\"paddingRight\":\"24\"}"
      },
      "tablet": {
        "stylingBox": "{\"paddingTop\":\"16\",\"paddingBottom\":\"16\",\"paddingLeft\":\"16\",\"paddingRight\":\"16\"}"
      },
      "mobile": {
        "stylingBox": "{\"paddingTop\":\"16\",\"paddingBottom\":\"16\",\"paddingLeft\":\"16\",\"paddingRight\":\"16\"}"
      }
    },
    "breadcrumbTrail": {
      "desktop": {
        "font": { "type": "Segoe UI", "size": 13, "weight": "400", "color": "#8c8c8c" },
        "stylingBox": "{\"marginBottom\":\"10\"}"
      },
      "tablet": {},
      "mobile": {}
    },
    "titleRow": {
      "desktop": {
        "stylingBox": "{\"marginBottom\":\"4\"}"
      },
      "tablet": {},
      "mobile": {}
    },
    "titleLeft": {
      "desktop": {
        "dimensions": { "width": "calc(100% - 220px)", "minWidth": "0px" }
      },
      "tablet": {
        "dimensions": { "width": "auto", "minWidth": "0px" }
      },
      "mobile": {
        "dimensions": { "width": "auto", "minWidth": "0px" }
      }
    },
    "titleText": {
      "desktop": {
        "font": { "type": "Segoe UI", "size": 24, "weight": "600", "color": "#262626" }
      },
      "tablet": {
        "font": { "type": "Segoe UI", "size": 20, "weight": "600", "color": "#262626" }
      },
      "mobile": {
        "font": { "type": "Segoe UI", "size": 18, "weight": "600", "color": "#262626" }
      }
    },
    "statusChip": {
      "desktop": {
        "font": { "type": "Segoe UI", "size": 11, "weight": "600", "align": "center" },
        "border": {
          "hideBorder": false,
          "radiusType": "all",
          "borderType": "all",
          "border": {
            "all": { "width": 0, "style": "none" },
            "top": {},
            "bottom": {},
            "left": {},
            "right": {}
          },
          "radius": { "all": 12 }
        },
        "stylingBox": "{\"paddingTop\":\"2\",\"paddingBottom\":\"2\",\"paddingLeft\":\"12\",\"paddingRight\":\"12\"}"
      },
      "tablet": {},
      "mobile": {}
    }
  }
}
