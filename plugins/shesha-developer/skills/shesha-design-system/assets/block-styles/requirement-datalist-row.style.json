{
  "$overlay": "requirement-datalist-row",
  "$note": "Brand visuals for the datalist row CARD (paired with the requirement-datalist-row block). Neutral channels only. rowCard = white surface, hairline border, radius 8, soft card shadow, 14x16 inner padding, minHeight fit-content (grows to content). rowBody = 14px ink paragraph. rowMeta text = 12px muted. CRITICAL: this overlay sets visuals ONLY — the collapse/scroll-arrow fix lives in the block subtree as `style` overflow values + the body minHeight reserve and must NOT be overwritten here. refListStatus pill colours come from the reference list (per-item), not this overlay. The datalist row gap (16) is owned by the host datalist, not the card.",
  "targets": {
    "rowCard": {
      "desktop": {
        "background": { "type": "color", "color": "#ffffff" },
        "border": { "hideBorder": false, "radiusType": "all", "borderType": "all", "border": { "all": { "width": "1px", "style": "solid", "color": "#e5e7eb" }, "top": {}, "bottom": {}, "left": {}, "right": {} }, "radius": { "all": 8 } },
        "shadow": { "offsetX": 0, "offsetY": 1, "blurRadius": 4, "spreadRadius": 0, "color": "rgba(0,0,0,0.06)" },
        "dimensions": { "width": "auto", "height": "auto", "minHeight": "fit-content", "maxHeight": "auto", "minWidth": "0px", "maxWidth": "100%" },
        "stylingBox": "{\"paddingTop\":\"14\",\"paddingRight\":\"16\",\"paddingBottom\":\"14\",\"paddingLeft\":\"16\"}",
        "enableStyleOnReadonly": false
      },
      "tablet": {
        "background": { "type": "color", "color": "#ffffff" },
        "border": { "hideBorder": false, "radiusType": "all", "borderType": "all", "border": { "all": { "width": "1px", "style": "solid", "color": "#e5e7eb" }, "top": {}, "bottom": {}, "left": {}, "right": {} }, "radius": { "all": 8 } },
        "shadow": { "offsetX": 0, "offsetY": 1, "blurRadius": 4, "spreadRadius": 0, "color": "rgba(0,0,0,0.06)" },
        "dimensions": { "width": "auto", "height": "auto", "minHeight": "fit-content", "maxWidth": "100%" },
        "stylingBox": "{\"paddingTop\":\"14\",\"paddingRight\":\"16\",\"paddingBottom\":\"14\",\"paddingLeft\":\"16\"}"
      },
      "mobile": {
        "background": { "type": "color", "color": "#ffffff" },
        "border": { "hideBorder": false, "radiusType": "all", "borderType": "all", "border": { "all": { "width": "1px", "style": "solid", "color": "#e5e7eb" }, "top": {}, "bottom": {}, "left": {}, "right": {} }, "radius": { "all": 8 } },
        "shadow": { "offsetX": 0, "offsetY": 1, "blurRadius": 4, "spreadRadius": 0, "color": "rgba(0,0,0,0.06)" },
        "dimensions": { "width": "auto", "height": "auto", "minHeight": "fit-content", "maxWidth": "100%" },
        "stylingBox": "{\"paddingTop\":\"14\",\"paddingRight\":\"16\",\"paddingBottom\":\"14\",\"paddingLeft\":\"16\"}"
      }
    },
    "rowHeader": {
      "desktop": { "dimensions": { "width": "100%", "minWidth": "100%", "maxWidth": "100%", "minHeight": "fit-content" }, "stylingBox": "{}" },
      "tablet": { "dimensions": { "width": "100%" } },
      "mobile": { "dimensions": { "width": "100%" } }
    },
    "rowHeaderLeft": {
      "desktop": { "dimensions": { "width": "fit-content", "minWidth": "0px", "maxWidth": "calc(100% - 80px)" } },
      "tablet": { "dimensions": { "width": "fit-content", "maxWidth": "calc(100% - 80px)" } },
      "mobile": { "dimensions": { "width": "fit-content", "maxWidth": "calc(100% - 72px)" } }
    },
    "rowNumberBadge": {
      "desktop": { "font": { "type": "Segoe UI", "size": 12, "weight": "700", "align": "left", "color": "#97a8a3" }, "border": {}, "background": {}, "shadow": {}, "stylingBox": "{}" },
      "tablet": {}, "mobile": {}
    },
    "rowBody": {
      "desktop": { "font": { "type": "Segoe UI", "size": 14, "weight": "500", "align": "left", "color": "$role:bodyText" }, "dimensions": { "width": "auto", "height": "auto", "minHeight": "24px", "maxHeight": "auto", "minWidth": "0px", "maxWidth": "100%" }, "border": {}, "background": {}, "shadow": {}, "stylingBox": "{\"marginTop\":\"2\",\"marginBottom\":\"2\"}" },
      "tablet": { "font": { "type": "Segoe UI", "size": 14, "weight": "500", "align": "left", "color": "$role:bodyText" } },
      "mobile": { "font": { "type": "Segoe UI", "size": 14, "weight": "500", "align": "left", "color": "$role:bodyText" } }
    },
    "rowMeta": {
      "desktop": { "dimensions": { "width": "100%", "height": "auto", "minHeight": "fit-content" }, "stylingBox": "{}" },
      "tablet": {}, "mobile": {}
    },
    "rowMetaText": {
      "$note": "Apply to each meta text component the form adds inside rowMeta (e.g. 'Release · …'). Muted 12px.",
      "desktop": { "font": { "type": "Segoe UI", "size": 12, "weight": "400", "align": "left", "color": "#6b7280" }, "border": {}, "background": {}, "shadow": {}, "stylingBox": "{}" },
      "tablet": {}, "mobile": {}
    }
  }
}
