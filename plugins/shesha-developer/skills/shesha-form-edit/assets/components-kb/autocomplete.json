{
  "type": "autocomplete",
  "name": "Autocomplete",
  "isInput": true,
  "isOutput": true,
  "canBeJsSetting": true,
  "icon": "FileSearchOutlined",
  "version": 6,
  "initModel": null,
  "settingsProps": {
    "interfaceName": "IAutocompleteComponentProps",
    "interfaceFile": "designer-components/autocomplete/interfaces.ts",
    "ownProps": [
      "entityTypeShortAlias",
      "entityDisplayProperty",
      "hideBorder",
      "dataSourceUrl",
      "dataSourceType",
      "mode",
      "useRawValues",
      "queryParams",
      "keyPropName",
      "valuePropName",
      "filter",
      "disableSearch",
      "placeholder",
      "quickviewEnabled",
      "quickviewFormPath",
      "quickviewDisplayPropertyName",
      "quickviewGetEntityUrl",
      "quickviewWidth",
      "width",
      "minWidth",
      "maxWidth",
      "allowFreeText",
      "borderSize",
      "borderRadius",
      "borderType",
      "borderColor",
      "fontSize",
      "fontWeight",
      "stylingBox",
      "height",
      "backgroundColor"
    ],
    "extends": [
      "IConfigurableFormComponent"
    ],
    "resolvedProps": [
      "allowFreeText",
      "backgroundColor",
      "borderColor",
      "borderRadius",
      "borderSize",
      "borderType",
      "componentName",
      "context",
      "customEnabled",
      "customVisibility",
      "dataSourceType",
      "dataSourceUrl",
      "defaultValue",
      "description",
      "disableSearch",
      "editMode",
      "entityDisplayProperty",
      "entityTypeShortAlias",
      "filter",
      "fontSize",
      "fontWeight",
      "height",
      "hidden",
      "hideBorder",
      "hideLabel",
      "id",
      "initialContext",
      "injectedDefaultValue",
      "injectedTableRow",
      "isDynamic",
      "jsSetting",
      "keyPropName",
      "label",
      "labelAlign",
      "maxWidth",
      "minWidth",
      "mode",
      "noDataIcon",
      "noDataSecondaryText",
      "noDataText",
      "onBlurCustom",
      "onChangeCustom",
      "onFocusCustom",
      "parentId",
      "permissions",
      "placeholder",
      "propertyName",
      "queryParams",
      "quickviewDisplayPropertyName",
      "quickviewEnabled",
      "quickviewFormPath",
      "quickviewGetEntityUrl",
      "quickviewWidth",
      "readOnly",
      "settingsValidationErrors",
      "size",
      "style",
      "stylingBox",
      "subscribedEventNames",
      "type",
      "useRawValues",
      "validate",
      "valuePropName",
      "width"
    ],
    "unresolvedExtends": [
      "IHasVersion"
    ]
  },
  "settingsForm": {
    "source": "autocomplete/settingsForm.json",
    "mechanism": "json-markup",
    "parseQuality": "full"
  },
  "hasStandardAppearance": true,
  "appearanceFieldPaths": [
    "style",
    "size",
    "height",
    "width",
    "hideBorder",
    "borderSize",
    "borderRadius",
    "borderType",
    "borderColor",
    "backgroundColor",
    "stylingBox"
  ],
  "settingsFields": [
    {
      "path": "propertyName",
      "label": "Property name",
      "editorType": "contextPropertyAutocomplete",
      "group": "Display"
    },
    {
      "path": "label",
      "label": "Label",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "labelAlign",
      "label": "Label align",
      "editorType": "dropdown",
      "group": "Display"
    },
    {
      "path": "hideLabel",
      "label": "Hide Label",
      "editorType": "checkbox",
      "group": "Display",
      "description": "Check this field to use your custom border."
    },
    {
      "path": "description",
      "label": "Description",
      "editorType": "textArea",
      "group": "Display"
    },
    {
      "path": "placeholder",
      "label": "Placeholder",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "mode",
      "label": "Selection Mode",
      "editorType": "dropdown",
      "group": "Display"
    },
    {
      "path": "disableSearch",
      "label": "Disable Search",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "hidden",
      "label": "Hidden",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "editMode",
      "label": "Edit mode",
      "editorType": "editModeSelector",
      "group": "Display"
    },
    {
      "path": "defaultValue",
      "label": "Default Value",
      "editorType": "codeEditor",
      "group": "Data",
      "description": "Enter default value for component. Multiple values are exposed."
    },
    {
      "path": "dataSourceType",
      "label": "Data Source type",
      "editorType": "dropdown",
      "group": "Data"
    },
    {
      "path": "dataSourceUrl",
      "label": "Data Source Url",
      "editorType": "textField",
      "group": "Data"
    },
    {
      "path": "keyPropName",
      "label": "Key Prop Name",
      "editorType": "textField",
      "group": "Data"
    },
    {
      "path": "valuePropName",
      "label": "Value Prop Name",
      "editorType": "textField",
      "group": "Data"
    },
    {
      "path": "queryParams",
      "label": "Query Param",
      "editorType": "labelValueEditor",
      "group": "Data"
    },
    {
      "path": "entityTypeShortAlias",
      "label": "Entity Type",
      "editorType": "autocomplete",
      "group": "Data"
    },
    {
      "path": "entityDisplayProperty",
      "label": "Display Property",
      "editorType": "propertyAutocomplete",
      "group": "Data",
      "description": "Name of the property that should be displayed in the autocomplete. Live empty to use default display property defined on the back-end."
    },
    {
      "path": "filter",
      "label": "Entity Filter",
      "editorType": "queryBuilder",
      "group": "Data"
    },
    {
      "path": "useRawValues",
      "label": "Use raw values",
      "editorType": "checkbox",
      "group": "Data"
    },
    {
      "path": "allowFreeText",
      "label": "Allow Free Text",
      "editorType": "checkbox",
      "group": "Data",
      "description": "Allow to use free text that is missing on the source"
    },
    {
      "path": "onChangeCustom",
      "label": "On Change",
      "editorType": "codeEditor",
      "group": "Events",
      "description": "Enter custom eventhandler on changing of event. (form, value, option) are exposed. Called when select an option or input value change"
    },
    {
      "path": "validate.required",
      "label": "Required",
      "editorType": "checkbox",
      "group": "Validation"
    },
    {
      "path": "quickviewEnabled",
      "label": "Use Quickview",
      "editorType": "checkbox",
      "group": "Quickview"
    },
    {
      "path": "quickviewFormPath",
      "label": "Form Path",
      "editorType": "formAutocomplete",
      "group": "Quickview"
    },
    {
      "path": "quickviewGetEntityUrl",
      "label": "Get Entity Url",
      "editorType": "textField",
      "group": "Quickview"
    },
    {
      "path": "quickviewDisplayPropertyName",
      "label": "Display Property Name",
      "editorType": "textField",
      "group": "Quickview"
    },
    {
      "path": "quickviewWidth",
      "label": "Width",
      "editorType": "textField",
      "group": "Quickview"
    },
    {
      "path": "permissions",
      "label": "Permissions",
      "editorType": "permissionAutocomplete",
      "group": "Security"
    }
  ],
  "slots": {
    "hostsChildren": false,
    "customContainerNames": null,
    "detectedSlotKeys": [],
    "usesComponentsContainer": false
  },
  "sourceFiles": [
    "autocomplete/autocomplete.tsx",
    "autocomplete/interfaces.ts"
  ]
}
