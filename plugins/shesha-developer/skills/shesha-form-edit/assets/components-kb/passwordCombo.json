{
  "type": "passwordCombo",
  "name": "Password combo",
  "isInput": true,
  "isOutput": null,
  "canBeJsSetting": null,
  "icon": "LockOutlined",
  "version": 6,
  "initModel": null,
  "settingsProps": {
    "interfaceName": "IPasswordComponentProps",
    "interfaceFile": "designer-components/passwordCombo/utils.ts",
    "ownProps": [
      "placeholder",
      "confirmDescription",
      "confirmPlaceholder",
      "confirmLabel",
      "hideBorder",
      "minLength",
      "message"
    ],
    "extends": [
      "IConfigurableFormComponent"
    ],
    "resolvedProps": [
      "componentName",
      "confirmDescription",
      "confirmLabel",
      "confirmPlaceholder",
      "context",
      "customEnabled",
      "customVisibility",
      "defaultValue",
      "description",
      "editMode",
      "hidden",
      "hideBorder",
      "hideLabel",
      "id",
      "initialContext",
      "injectedDefaultValue",
      "injectedTableRow",
      "isDynamic",
      "jsSetting",
      "label",
      "labelAlign",
      "message",
      "minLength",
      "noDataIcon",
      "noDataSecondaryText",
      "noDataText",
      "onBlurCustom",
      "onChangeCustom",
      "onFocusCustom",
      "parentId",
      "permissions",
      "placeholder",
      "propertyName",
      "readOnly",
      "settingsValidationErrors",
      "size",
      "style",
      "stylingBox",
      "subscribedEventNames",
      "type",
      "validate"
    ],
    "unresolvedExtends": [
      "IHasVersion"
    ]
  },
  "settingsForm": {
    "source": "passwordCombo/settingsForm.json",
    "mechanism": "json-markup",
    "parseQuality": "full"
  },
  "hasStandardAppearance": false,
  "appearanceFieldPaths": [
    "hideBorder",
    "style",
    "size"
  ],
  "settingsFields": [
    {
      "path": "propertyName",
      "label": "Property name",
      "editorType": "propertyAutocomplete",
      "group": "Display"
    },
    {
      "path": "label",
      "label": "Label",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "confirmLabel",
      "label": "Label: Confirmation",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "labelAlign",
      "label": "Label align",
      "editorType": "dropdown",
      "group": "Display"
    },
    {
      "path": "placeholder",
      "label": "Placeholder",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "confirmPlaceholder",
      "label": "Placeholder: Confirmation",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "description",
      "label": "Description",
      "editorType": "textArea",
      "group": "Display"
    },
    {
      "path": "confirmDescription",
      "label": "Description: Confirmation",
      "editorType": "textArea",
      "group": "Display"
    },
    {
      "path": "hidden",
      "label": "Hidden",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "hideLabel",
      "label": "Hide Label",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "editMode",
      "label": "Edit mode",
      "editorType": "editModeSelector",
      "group": "Display"
    },
    {
      "path": "validate.required",
      "label": "Required",
      "editorType": "checkbox",
      "group": "Validation"
    },
    {
      "path": "minLength",
      "label": "Min Password Length",
      "editorType": "numberField",
      "defaultValue": 4,
      "group": "Validation"
    },
    {
      "path": "message",
      "label": "Message",
      "editorType": "textField",
      "group": "Validation"
    },
    {
      "path": "validate.validator",
      "label": "Validator",
      "editorType": "codeEditor",
      "group": "Validation",
      "description": "Enter custom validator logic for form.item rules. Returns a Promise"
    },
    {
      "path": "hideBorder",
      "label": "Hide border",
      "editorType": "checkbox",
      "group": "Style",
      "shared": true
    },
    {
      "path": "style",
      "label": "Style",
      "editorType": "codeEditor",
      "group": "Style",
      "description": "A script that returns the style of the element as an object. This should conform to CSSProperties",
      "shared": true
    },
    {
      "path": "size",
      "label": "Size",
      "editorType": "dropdown",
      "group": "Style",
      "shared": true
    },
    {
      "path": "permissions",
      "label": "Permissions",
      "editorType": "permissionAutocomplete",
      "group": "Security"
    }
  ],
  "slots": {
    "hostsChildren": false,
    "customContainerNames": null,
    "detectedSlotKeys": [],
    "usesComponentsContainer": false
  },
  "sourceFiles": [
    "passwordCombo/index.tsx",
    "passwordCombo/utils.ts"
  ]
}
