{
  "type": "propertyAutocomplete",
  "name": "Property Autocomplete",
  "isInput": true,
  "isOutput": true,
  "canBeJsSetting": null,
  "icon": "FileSearchOutlined",
  "version": 2,
  "initModel": null,
  "settingsProps": {
    "interfaceName": "IPropertyAutocompleteComponentProps",
    "interfaceFile": "designer-components/propertyAutocomplete/interfaces.ts",
    "ownProps": [
      "dropdownStyle",
      "mode",
      "modelType",
      "autoFillProps"
    ],
    "extends": [
      "IConfigurableFormComponent"
    ],
    "resolvedProps": [
      "autoFillProps",
      "componentName",
      "context",
      "customEnabled",
      "customVisibility",
      "defaultValue",
      "description",
      "dropdownStyle",
      "editMode",
      "hidden",
      "hideLabel",
      "id",
      "initialContext",
      "injectedDefaultValue",
      "injectedTableRow",
      "isDynamic",
      "jsSetting",
      "label",
      "labelAlign",
      "mode",
      "modelType",
      "noDataIcon",
      "noDataSecondaryText",
      "noDataText",
      "onBlurCustom",
      "onChangeCustom",
      "onFocusCustom",
      "parentId",
      "permissions",
      "propertyName",
      "readOnly",
      "settingsValidationErrors",
      "size",
      "style",
      "stylingBox",
      "subscribedEventNames",
      "type",
      "validate"
    ],
    "unresolvedExtends": [
      "IHasVersion"
    ]
  },
  "settingsForm": {
    "source": "propertyAutocomplete/settingsForm.json",
    "mechanism": "json-markup",
    "parseQuality": "full"
  },
  "hasStandardAppearance": false,
  "appearanceFieldPaths": [
    "hideBorder",
    "style",
    "size"
  ],
  "settingsFields": [
    {
      "path": "propertyName",
      "label": "Property name",
      "editorType": "contextPropertyAutocomplete"
    },
    {
      "path": "label",
      "label": "Label",
      "editorType": "textField"
    },
    {
      "path": "labelAlign",
      "label": "Label align",
      "editorType": "dropdown"
    },
    {
      "path": "placeholder",
      "label": "Placeholder",
      "editorType": "textField"
    },
    {
      "path": "description",
      "label": "Description",
      "editorType": "textArea"
    },
    {
      "path": "hidden",
      "label": "Hidden",
      "editorType": "checkbox"
    },
    {
      "path": "hideLabel",
      "label": "Hide Label",
      "editorType": "checkbox"
    },
    {
      "path": "editMode",
      "label": "Edit mode",
      "editorType": "editModeSelector"
    },
    {
      "path": "hideBorder",
      "label": "Hide border",
      "editorType": "checkbox",
      "shared": true
    },
    {
      "path": "modelType",
      "label": "Entity type",
      "editorType": "textField",
      "description": "Type of model. Leave empty to use default model type available in the current MetadataProvider"
    },
    {
      "path": "autoFillProps",
      "label": "Auto `Fill Props` label",
      "editorType": "checkbox"
    },
    {
      "path": "mode",
      "label": "Mode",
      "editorType": "dropdown"
    },
    {
      "path": "validate.required",
      "label": "Required",
      "editorType": "checkbox"
    },
    {
      "path": "style",
      "label": "Style",
      "editorType": "codeEditor",
      "description": "A script that returns the style of the element as an object. This should conform to CSSProperties",
      "shared": true
    },
    {
      "path": "size",
      "label": "Size",
      "editorType": "dropdown",
      "shared": true
    }
  ],
  "slots": {
    "hostsChildren": false,
    "customContainerNames": null,
    "detectedSlotKeys": [],
    "usesComponentsContainer": false
  },
  "sourceFiles": [
    "propertyAutocomplete/index.tsx",
    "propertyAutocomplete/interfaces.ts"
  ]
}
