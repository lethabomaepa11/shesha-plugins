    "raw": "model => ({\r\n    code: false,\r\n    copyable: false,\r\n    delete: false,\r\n    ellipsis: false,\r\n    mark: false,\r\n    italic: false,\r\n    underline: false,\r\n    level: 1,\r\n    textType: 'span',\r\n    ...model,\r\n  })"
