{
  "type": "textField",
  "name": "Text field",
  "isInput": true,
  "isOutput": true,
  "canBeJsSetting": true,
  "icon": "CodeOutlined",
  "version": 5,
  "initModel": {
    "defaults": {
      "textType": "text"
    },
    "raw": "(model) => ({\r\n    textType: 'text',\r\n    ...model,\r\n  })"
  },
  "settingsProps": {
    "interfaceName": "ITextFieldComponentProps",
    "interfaceFile": "designer-components/textField/interfaces.ts",
    "ownProps": [
      "desktop",
      "tablet",
      "mobile",
      "placeholder",
      "prefix",
      "suffix",
      "suffixIcon",
      "prefixIcon",
      "initialValue",
      "passEmptyStringByDefault",
      "textType",
      "spellCheck"
    ],
    "extends": [
      "IConfigurableFormComponent",
      "IInputStyles"
    ],
    "resolvedProps": [
      "backgroundColor",
      "borderColor",
      "borderRadius",
      "borderSize",
      "borderType",
      "componentName",
      "context",
      "customEnabled",
      "customVisibility",
      "defaultValue",
      "description",
      "desktop",
      "editMode",
      "fontColor",
      "fontSize",
      "fontWeight",
      "height",
      "hidden",
      "hideBorder",
      "hideLabel",
      "id",
      "initialContext",
      "initialValue",
      "injectedDefaultValue",
      "injectedTableRow",
      "isDynamic",
      "jsSetting",
      "label",
      "labelAlign",
      "mobile",
      "noDataIcon",
      "noDataSecondaryText",
      "noDataText",
      "onBlurCustom",
      "onChangeCustom",
      "onFocusCustom",
      "parentId",
      "passEmptyStringByDefault",
      "permissions",
      "placeholder",
      "prefix",
      "prefixIcon",
      "propertyName",
      "readOnly",
      "settingsValidationErrors",
      "size",
      "spellCheck",
      "style",
      "stylingBox",
      "subscribedEventNames",
      "suffix",
      "suffixIcon",
      "tablet",
      "textType",
      "type",
      "validate",
      "width"
    ],
    "unresolvedExtends": [
      "IHasVersion"
    ]
  },
  "settingsForm": {
    "source": "textField/settingsForm.json",
    "mechanism": "json-markup",
    "parseQuality": "full"
  },
  "hasStandardAppearance": true,
  "appearanceFieldPaths": [
    "style",
    "size",
    "height",
    "width",
    "hideBorder",
    "borderSize",
    "borderRadius",
    "borderType",
    "borderColor",
    "fontSize",
    "fontColor",
    "backgroundColor",
    "stylingBox"
  ],
  "settingsFields": [
    {
      "path": "propertyName",
      "label": "Property name",
      "editorType": "contextPropertyAutocomplete",
      "group": "Display"
    },
    {
      "path": "label",
      "label": "Label",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "textType",
      "label": "Type",
      "editorType": "dropdown",
      "group": "Display"
    },
    {
      "path": "labelAlign",
      "label": "Label align",
      "editorType": "dropdown",
      "group": "Display"
    },
    {
      "path": "placeholder",
      "label": "Placeholder",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "description",
      "label": "Description",
      "editorType": "textArea",
      "group": "Display"
    },
    {
      "path": "prefix",
      "label": "Prefix",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "prefixIcon",
      "label": "Prefix Icon",
      "editorType": "iconPicker",
      "group": "Display"
    },
    {
      "path": "suffix",
      "label": "Suffix",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "suffixIcon",
      "label": "Suffix Icon",
      "editorType": "iconPicker",
      "group": "Display"
    },
    {
      "path": "initialValue",
      "label": "Default Value",
      "editorType": "textField",
      "group": "Display",
      "description": "Enter default value of component. (formData, formMode, globalState) are exposed"
    },
    {
      "path": "passEmptyStringByDefault",
      "label": "Empty as default",
      "editorType": "checkbox",
      "group": "Display",
      "description": "Whether the component should be initialized with an empty string"
    },
    {
      "path": "hidden",
      "label": "Hidden",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "hideLabel",
      "label": "Hide Label",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "editMode",
      "label": "Edit mode",
      "editorType": "editModeSelector",
      "group": "Display"
    },
    {
      "path": "onChangeCustom",
      "label": "On Change",
      "editorType": "codeEditor",
      "group": "Events",
      "description": "Enter custom eventhandler on changing of event. (form, event) are exposed"
    },
    {
      "path": "onFocusCustom",
      "label": "On Focus",
      "editorType": "codeEditor",
      "group": "Events",
      "description": "Enter custom eventhandler on focus of event. (form, event) are exposed"
    },
    {
      "path": "onBlurCustom",
      "label": "On Blur",
      "editorType": "codeEditor",
      "group": "Events",
      "description": "Enter custom eventhandler on blur of event. (form, event) are exposed"
    },
    {
      "path": "validate.required",
      "label": "Required",
      "editorType": "checkbox",
      "group": "Validation"
    },
    {
      "path": "validate.minLength",
      "label": "Min Length",
      "editorType": "numberField",
      "group": "Validation"
    },
    {
      "path": "validate.maxLength",
      "label": "Max Length",
      "editorType": "numberField",
      "group": "Validation"
    },
    {
      "path": "validate.message",
      "label": "Message",
      "editorType": "textField",
      "group": "Validation"
    },
    {
      "path": "validate.validator",
      "label": "Validator",
      "editorType": "codeEditor",
      "group": "Validation",
      "description": "Enter custom validator logic for form.item rules. Returns a Promise"
    },
    {
      "path": "spellCheck",
      "label": "Spell Check",
      "editorType": "checkbox",
      "group": "Validation"
    },
    {
      "path": "permissions",
      "label": "Permissions",
      "editorType": "permissionAutocomplete",
      "group": "Security"
    }
  ],
  "slots": {
    "hostsChildren": false,
    "customContainerNames": null,
    "detectedSlotKeys": [],
    "usesComponentsContainer": false
  },
  "sourceFiles": [
    "textField/textField.tsx",
    "textField/interfaces.ts"
  ]
}
