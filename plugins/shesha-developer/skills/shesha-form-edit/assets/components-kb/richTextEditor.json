      "width",
      "minWidth",
      "maxWidth",
      "saveHeightInStorage",
      "saveModeInStorage",
      "askBeforePasteHTML",
      "askBeforePasteFromWord"
    ],
    "extends": [
      "IConfigurableFormComponent"
    ],
    "resolvedProps": [
      "allowResizeX",
      "allowResizeY",
      "askBeforePasteFromWord",
      "askBeforePasteHTML",
      "autoHeight",
      "autoWidth",
      "autofocus",
      "componentName",
      "context",
      "customEnabled",
      "customVisibility",
      "defaultMode",
      "defaultValue",
      "description",
      "direction",
      "disablePlugins",
      "editMode",
      "enter",
      "height",
      "hidden",
      "hideLabel",
      "id",
      "iframe",
      "initialContext",
      "injectedDefaultValue",
      "injectedTableRow",
      "insertImageAsBase64URI",
      "isDynamic",
      "jsSetting",
      "label",
      "labelAlign",
      "maxHeight",
      "maxWidth",
      "minHeight",
      "minWidth",
      "noDataIcon",
      "noDataSecondaryText",
      "noDataText",
      "onBlurCustom",
      "onChangeCustom",
      "onFocusCustom",
      "parentId",
      "permissions",
      "placeholder",
      "preset",
      "propertyName",
      "readOnly",
      "saveHeightInStorage",
      "saveModeInStorage",
      "settingsValidationErrors",
      "showCharsCounter",
      "showWordsCounter",
      "showXPathInStatusbar",
      "size",
      "spellcheck",
      "style",
