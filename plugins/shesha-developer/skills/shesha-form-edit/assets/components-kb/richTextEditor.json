      "theme",
      "toolbar",
      "toolbarButtonSize",
      "toolbarSticky",
      "toolbarStickyOffset",
      "type",
      "useSearch",
      "validate",
      "width"
    ],
    "unresolvedExtends": [
      "IHasVersion"
    ]
  },
  "settingsForm": {
    "source": "richTextEditor/settingsForm.json",
    "mechanism": "json-markup",
    "parseQuality": "full"
  },
  "hasStandardAppearance": false,
  "appearanceFieldPaths": [
    "height",
    "width",
    "style"
  ],
  "settingsFields": [
