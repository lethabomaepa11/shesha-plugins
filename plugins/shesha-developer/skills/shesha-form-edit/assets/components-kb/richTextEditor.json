    {
      "path": "showWordsCounter",
      "label": "Show words counter",
      "editorType": "checkbox",
      "group": "Options"
    },
    {
      "path": "showXPathInStatusbar",
      "label": "Show path to selected element",
      "editorType": "checkbox",
