{
  "type": "richTextEditor",
  "name": "Rich Text Editor",
  "isInput": true,
  "isOutput": true,
  "canBeJsSetting": null,
  "icon": "EditOutlined",
  "version": 3,
  "initModel": {
    "defaults": {
      "showCharsCounter": true,
      "showWordsCounter": true,
      "showXPathInStatusbar": true,
      "minHeight": 200,
      "minWidth": 200,
      "toolbar": true,
      "useSearch": true,
      "autoHeight": true,
      "autoWidth": true,
      "askBeforePasteHTML": true,
      "askBeforePasteFromWord": true,
      "disablePlugins": null
    },
    "raw": "model => ({\r\n    ...model,\r\n    showCharsCounter: true,\r\n    showWordsCounter: true,\r\n    showXPathInStatusbar: true,\r\n    minHeight: 200,\r\n    minWidth: 200,\r\n    toolbar: true,\r\n    useSearch: true,\r\n    autoHeight: true,\r\n    autoWidth: true,\r\n    askBeforePasteHTML: true,\r\n    askBeforePasteFromWord: true,\r\n    disablePlugins: null,\r\n  })"
  },
  "settingsProps": {
    "interfaceName": "IRichTextEditorProps",
    "interfaceFile": "designer-components/richTextEditor/interfaces.ts",
    "ownProps": [
      "placeholder",
      "toolbar",
      "textIcons",
      "preset",
      "toolbarButtonSize",
      "toolbarStickyOffset",
      "theme",
      "toolbarSticky",
      "autofocus",
      "useSearch",
      "iframe",
      "spellcheck",
      "direction",
      "enter",
      "defaultMode",
      "showCharsCounter",
      "showWordsCounter",
      "showXPathInStatusbar",
      "disablePlugins",
      "insertImageAsBase64URI",
      "autoHeight",
      "allowResizeY",
      "height",
