  "isOutput": true,
  "canBeJsSetting": null,
  "icon": "FileAddOutlined",
  "version": 5,
  "initModel": {
    "defaults": null,
    "raw": "model => {\r\n    const customModel: IFileUploadProps = {\r\n      ...model,\r\n      allowReplace: true,\r\n      allowDelete: true,\r\n      allowUpload: true,\r\n      ownerId: '',\r\n      ownerType: '',\r\n      isDragger: false,\r\n    };\r\n    return customModel;\r\n  }"
  },
  "settingsProps": {
    "interfaceName": "IFileUploadProps",
