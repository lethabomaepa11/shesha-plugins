    "ownProps": [
      "ownerId",
      "ownerType",
      "allowUpload",
      "allowReplace",
      "allowDelete",
      "useSync",
      "allowedFileTypes",
      "isDragger"
    ],
    "extends": [
      "IConfigurableFormComponent",
      "Omit<IFormItem",
      "'name'>"
