      "onChangeCustom",
      "onFocusCustom",
      "parentId",
      "passEmptyStringByDefault",
      "permissions",
      "placeholder",
      "propertyName",
      "readOnly",
      "settingsValidationErrors",
      "showCount",
      "size",
      "spellCheck",
      "style",
      "stylingBox",
      "subscribedEventNames",
      "type",
      "validate",
      "width"
