    "defaults": null,
    "raw": "(model) => {\r\n    const textAreaModel: ITextAreaComponentProps = {\r\n      ...model,\r\n      label: 'Text Area',\r\n      autoSize: false,\r\n      showCount: false,\r\n      allowClear: false,\r\n    };\r\n\r\n    return textAreaModel;\r\n  }"
  },
  "settingsProps": {
