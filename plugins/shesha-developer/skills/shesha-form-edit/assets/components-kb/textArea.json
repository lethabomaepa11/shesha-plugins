    },
    {
      "path": "autoSize",
      "label": "Auto size",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "allowClear",
      "label": "Allow clear",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "showCount",
      "label": "Show chars count",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "hidden",
      "label": "Hidden",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "hideLabel",
      "label": "Hide Label",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "editMode",
      "label": "Edit mode",
      "editorType": "editModeSelector",
      "group": "Display"
    },
    {
      "path": "onChangeCustom",
      "label": "On Change",
      "editorType": "codeEditor",
      "group": "Events",
      "description": "Enter custom eventhandler on changing of event. (form, event) are exposed"
    },
    {
      "path": "onFocusCustom",
      "label": "On Focus",
      "editorType": "codeEditor",
      "group": "Events",
      "description": "Enter custom eventhandler on focus of event. (form, event) are exposed"
    },
    {
      "path": "onBlurCustom",
      "label": "On Blur",
      "editorType": "codeEditor",
      "group": "Events",
      "description": "Enter custom eventhandler on blur of event. (form, event) are exposed"
    },
    {
      "path": "validate.required",
      "label": "Required",
      "editorType": "checkbox",
      "group": "Validation"
    },
    {
      "path": "validate.minLength",
      "label": "Min Length",
      "editorType": "numberField",
      "group": "Validation"
    },
    {
      "path": "validate.maxLength",
      "label": "Max Length",
      "editorType": "numberField",
      "group": "Validation"
    },
    {
      "path": "validate.message",
      "label": "Message",
      "editorType": "textField",
      "group": "Validation"
    },
    {
      "path": "validate.validator",
      "label": "Validator",
      "editorType": "codeEditor",
      "group": "Validation",
      "description": "Enter custom validator logic for form.item rules. Customize validation rule. Accept Promise as return."
    },
    {
      "path": "spellCheck",
      "label": "Spell Check",
      "editorType": "checkbox",
      "group": "Validation"
    },
    {
      "path": "permissions",
      "label": "Permissions",
      "editorType": "permissionAutocomplete",
      "group": "Security"
    }
  ],
  "slots": {
    "hostsChildren": false,
    "customContainerNames": null,
