{
  "type": "configurableItemAutocomplete",
  "name": "Configurable Item Autocomplete",
  "isInput": true,
  "isOutput": true,
  "canBeJsSetting": true,
  "icon": "FileSearchOutlined",
  "version": 0,
  "initModel": null,
  "settingsProps": {
    "interfaceName": "IConfigurableItemAutocompleteComponentProps",
    "interfaceFile": "designer-components/configurableItemAutocomplete/interfaces.ts",
    "ownProps": [
      "entityType",
      "mode",
      "filter"
    ],
    "extends": [
      "IConfigurableFormComponent"
    ],
    "resolvedProps": [
      "componentName",
      "context",
      "customEnabled",
      "customVisibility",
      "defaultValue",
      "description",
      "editMode",
      "entityType",
      "filter",
      "hidden",
      "hideLabel",
      "id",
      "initialContext",
      "injectedDefaultValue",
      "injectedTableRow",
      "isDynamic",
      "jsSetting",
      "label",
      "labelAlign",
      "mode",
      "noDataIcon",
      "noDataSecondaryText",
      "noDataText",
      "onBlurCustom",
      "onChangeCustom",
      "onFocusCustom",
      "parentId",
      "permissions",
      "propertyName",
      "readOnly",
      "settingsValidationErrors",
      "size",
      "style",
      "stylingBox",
      "subscribedEventNames",
      "type",
      "validate"
    ],
    "unresolvedExtends": [
      "IHasVersion"
    ]
  },
  "settingsForm": {
    "source": "configurableItemAutocomplete/settingsForm.json",
    "mechanism": "json-markup",
    "parseQuality": "full"
  },
  "hasStandardAppearance": false,
  "appearanceFieldPaths": [
    "style",
    "size"
  ],
  "settingsFields": [
    {
      "path": "propertyName",
      "label": "Property name",
      "editorType": "contextPropertyAutocomplete",
      "group": "Display"
    },
    {
      "path": "label",
      "label": "Label",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "labelAlign",
      "label": "Label align",
      "editorType": "dropdown",
      "group": "Display"
    },
    {
      "path": "placeholder",
      "label": "Placeholder",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "description",
      "label": "Description",
      "editorType": "textArea",
      "group": "Display"
    },
    {
      "path": "hidden",
      "label": "Hidden",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "hideLabel",
      "label": "Hide Label",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "editMode",
      "label": "Edit mode",
      "editorType": "editModeSelector",
      "group": "Display"
    },
    {
      "path": "entityType",
      "label": "Entity Type",
      "editorType": "autocomplete",
      "group": "Data"
    },
    {
      "path": "filter",
      "label": "Entity Filter",
      "editorType": "queryBuilder",
      "group": "Data"
    },
    {
      "path": "mode",
      "label": "Selection Mode",
      "editorType": "dropdown",
      "group": "Data"
    },
    {
      "path": "validate.required",
      "label": "Required",
      "editorType": "checkbox",
      "group": "Validation"
    },
    {
      "path": "validate.message",
      "label": "Message",
      "editorType": "textField",
      "group": "Validation"
    },
    {
      "path": "validate.validator",
      "label": "Validator",
      "editorType": "codeEditor",
      "group": "Validation",
      "description": "Enter custom validator logic for form.item rules. Returns a Promise"
    },
    {
      "path": "style",
      "label": "Style",
      "editorType": "codeEditor",
      "group": "Style",
      "description": "A script that returns the style of the element as an object. This should conform to CSSProperties",
      "shared": true
    },
    {
      "path": "size",
      "label": "Size",
      "editorType": "dropdown",
      "shared": true
    },
    {
      "path": "permissions",
      "label": "Permissions",
      "editorType": "permissionAutocomplete",
      "group": "Security"
    }
  ],
  "slots": {
    "hostsChildren": false,
    "customContainerNames": null,
    "detectedSlotKeys": [],
    "usesComponentsContainer": false
  },
  "sourceFiles": [
    "configurableItemAutocomplete/index.tsx",
    "configurableItemAutocomplete/interfaces.ts"
  ]
}
