{
  "type": "permissionsTree",
  "name": "Permissions tree",
  "isInput": true,
  "isOutput": true,
  "canBeJsSetting": null,
  "icon": "ApartmentOutlined",
  "version": 2,
  "initModel": {
    "defaults": null,
    "raw": "(model: IPermissionsTreeComponentProps) => {\r\n    return {\r\n      ...model,\r\n    };\r\n  }"
  },
  "settingsProps": {
    "interfaceName": "IPermissionsTreeComponentProps",
    "interfaceFile": "designer-components/permissions/permissionsTree/permissionsTree.tsx",
    "ownProps": [
      "value",
      "updateKey",
      "onChange",
      "disabled",
      "readOnly",
      "height",
      "mode",
      "onSelectAction"
    ],
    "extends": [
      "IConfigurableFormComponent"
    ],
    "resolvedProps": [
      "componentName",
      "context",
      "customEnabled",
      "customVisibility",
      "defaultValue",
      "description",
      "disabled",
      "editMode",
      "height",
      "hidden",
      "hideLabel",
      "id",
      "initialContext",
      "injectedDefaultValue",
      "injectedTableRow",
      "isDynamic",
      "jsSetting",
      "label",
      "labelAlign",
      "mode",
      "noDataIcon",
      "noDataSecondaryText",
      "noDataText",
      "onBlurCustom",
      "onChange",
      "onChangeCustom",
      "onFocusCustom",
      "onSelectAction",
      "parentId",
      "permissions",
      "propertyName",
      "readOnly",
      "settingsValidationErrors",
      "size",
      "style",
      "stylingBox",
      "subscribedEventNames",
      "type",
      "updateKey",
      "validate",
      "value"
    ],
    "unresolvedExtends": [
      "IHasVersion"
    ]
  },
  "settingsForm": {
    "source": "permissions/permissionsTree/settingsForm.json",
    "mechanism": "json-markup",
    "parseQuality": "full"
  },
  "hasStandardAppearance": false,
  "appearanceFieldPaths": [
    "height"
  ],
  "settingsFields": [
    {
      "path": "propertyName",
      "label": "Property name",
      "editorType": "contextPropertyAutocomplete"
    },
    {
      "path": "label",
      "label": "Label",
      "editorType": "textField"
    },
    {
      "path": "mode",
      "label": "Mode",
      "editorType": "dropdown"
    },
    {
      "path": "onSelectAction",
      "label": "On select action",
      "editorType": "configurableActionConfigurator"
    },
    {
      "path": "hidden",
      "label": "Hidden",
      "editorType": "checkbox"
    },
    {
      "path": "hideLabel",
      "label": "Hide Label",
      "editorType": "checkbox"
    },
    {
      "path": "editMode",
      "label": "Edit mode",
      "editorType": "editModeSelector"
    },
    {
      "path": "height",
      "label": "Height",
      "editorType": "numberField",
      "shared": true
    }
  ],
  "slots": {
    "hostsChildren": false,
    "customContainerNames": null,
    "detectedSlotKeys": [],
    "usesComponentsContainer": false
  },
  "sourceFiles": [
    "permissions/permissionsTree/permissionsTree.tsx"
  ]
}
