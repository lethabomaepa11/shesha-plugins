    },
    {
      "path": "hidden",
      "label": "Hidden",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "editMode",
      "label": "Edit mode",
      "editorType": "editModeSelector",
      "group": "Display"
    },
    {
      "path": "propertyRouteName",
      "label": "Property route name",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "permissions",
      "label": "Permissions",
      "editorType": "permissionAutocomplete",
      "group": "Security"
    }
  ],
  "slots": {
    "hostsChildren": true,
    "customContainerNames": null,
    "detectedSlotKeys": [
      "components"
    ],
    "usesComponentsContainer": true
  },
  "sourceFiles": [
    "propertyRouter/index.tsx"
  ]
