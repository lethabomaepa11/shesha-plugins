{
  "type": "imageAnnotation",
  "name": "ImageAnnotation",
  "isInput": true,
  "isOutput": true,
  "canBeJsSetting": null,
  "icon": "FileImageOutlined",
  "version": 3,
  "initModel": {
    "defaults": null,
    "raw": "model => {\r\n    const customModel: IImageProps = {\r\n      ...model,\r\n    };\r\n    return customModel;\r\n  }"
  },
  "settingsProps": {
    "interfaceName": "IImageProps",
    "interfaceFile": "designer-components/image/index.tsx",
    "ownProps": [
      "url",
      "storedFileId",
      "base64",
      "dataSource",
      "ownerType",
      "ownerId",
      "fileCategory",
      "allowPreview",
      "allowedFileTypes",
      "alt"
    ],
    "extends": [
      "IConfigurableFormComponent",
      "IFormItem",
      "IImageStyleProps"
    ],
    "resolvedProps": [
      "allowPreview",
      "allowedFileTypes",
      "alt",
      "base64",
      "borderColor",
      "borderRadius",
      "borderSize",
      "borderType",
      "componentName",
      "context",
      "customEnabled",
      "customVisibility",
      "dataSource",
      "defaultValue",
      "description",
      "editMode",
      "fileCategory",
      "filter",
      "height",
      "hidden",
      "hideLabel",
      "id",
      "initialContext",
      "injectedDefaultValue",
      "injectedTableRow",
      "isDynamic",
      "jsSetting",
      "label",
      "labelAlign",
      "name",
      "noDataIcon",
      "noDataSecondaryText",
      "noDataText",
      "objectFit",
      "objectPosition",
      "onBlurCustom",
      "onChange",
      "onChangeCustom",
      "onFocusCustom",
      "opacity",
      "ownerId",
      "ownerType",
      "parentId",
      "permissions",
      "propertyName",
      "readOnly",
      "settingsValidationErrors",
      "size",
      "storedFileId",
      "style",
      "stylingBox",
      "subscribedEventNames",
      "type",
      "url",
      "validate",
      "value",
      "width"
    ],
    "unresolvedExtends": [
      "IHasVersion"
    ]
  },
  "settingsForm": {
    "source": "imageAnnotation/settings.ts",
    "mechanism": "fluent-builder",
    "parseQuality": "full"
  },
  "hasStandardAppearance": false,
  "appearanceFieldPaths": [
    "style",
    "height",
    "width"
  ],
  "settingsFields": [
    {
      "path": "propertyName",
      "label": "Property mame",
      "editorType": "contextPropertyAutocomplete",
      "group": "Display"
    },
    {
      "path": "label",
      "label": "Label",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "labelAlign",
      "label": "Label align",
      "editorType": "dropdown",
      "group": "Display"
    },
    {
      "path": "description",
      "label": "Description",
      "editorType": "textArea",
      "group": "Display"
    },
    {
      "path": "hideLabel",
      "label": "Hide Label",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "editMode",
      "label": "Edit mode",
      "editorType": "editModeSelector",
      "group": "Display"
    },
    {
      "path": "validate.required",
      "label": "Required",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "style",
      "label": "Style",
      "editorType": "codeEditor",
      "description": "A script that returns the style of the element as an object. This should conform to CSSProperties",
      "group": "Display",
      "shared": true
    },
    {
      "path": "isOnImage",
      "label": "Annotation on Image",
      "editorType": "checkbox",
      "description": "This property allows for annotation decriptions to be either on top of the image or on the side of the image.",
      "group": "Customize Annotation"
    },
    {
      "path": "allowAddingNotes",
      "label": "Allow adding notes",
      "editorType": "checkbox",
      "defaultValue": true,
      "description": "This property allows notes/comments to be added for each annotation or just have number as annotations.",
      "group": "Customize Annotation"
    },
    {
      "path": "minPoints",
      "label": "Min number of points",
      "editorType": "numberField",
      "description": "This property denote least number of marks/points an image must have.",
      "group": "Customize Annotation"
    },
    {
      "path": "maxPoints",
      "label": "Max number of points",
      "editorType": "numberField",
      "description": "This property denote at most possible marks/points an image could have.",
      "group": "Customize Annotation"
    },
    {
      "path": "height",
      "label": "Height",
      "editorType": "numberField",
      "description": "This property determines the height of the image in question.",
      "group": "File",
      "shared": true
    },
    {
      "path": "width",
      "label": "Width",
      "editorType": "numberField",
      "description": "This property determines the width of the image in question.",
      "group": "File",
      "shared": true
    },
    {
      "path": "url",
      "label": "Url",
      "editorType": "codeEditor",
      "description": "A script that returns the image url as a string. This should return a string",
      "group": "File"
    },
    {
      "path": "permissions",
      "label": "Permissions",
      "editorType": "permissionAutocomplete",
      "group": "Security"
    }
  ],
  "slots": {
    "hostsChildren": false,
    "customContainerNames": null,
    "detectedSlotKeys": [],
    "usesComponentsContainer": false
  },
  "sourceFiles": [
    "imageAnnotation/index.tsx",
    "image/index.tsx"
  ]
}
