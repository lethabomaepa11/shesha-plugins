{
  "type": "button",
  "name": "Button",
  "isInput": false,
  "isOutput": null,
  "canBeJsSetting": null,
  "icon": "BorderOutlined",
  "version": 7,
  "initModel": {
    "defaults": null,
    "raw": "model => {\r\n    const buttonModel: IButtonComponentProps = {\r\n      ...model,\r\n      label: 'Submit',\r\n      actionConfiguration: makeDefaultActionConfiguration({ actionName: 'Submit', actionOwner: 'Form' }),\r\n      buttonType: 'default',\r\n    };\r\n    return buttonModel;\r\n  }"
  },
  "settingsProps": {
    "interfaceName": "IButtonComponentProps",
    "interfaceFile": "designer-components/button/interfaces.ts",
    "ownProps": [],
    "extends": [
      "IButtonItem",
      "IConfigurableFormComponent"
    ],
    "resolvedProps": [
      "componentName",
      "context",
      "customEnabled",
      "customVisibility",
      "defaultValue",
      "description",
      "editMode",
      "hidden",
      "hideLabel",
      "id",
      "initialContext",
      "injectedDefaultValue",
      "injectedTableRow",
      "isDynamic",
      "jsSetting",
      "label",
      "labelAlign",
      "noDataIcon",
      "noDataSecondaryText",
      "noDataText",
      "onBlurCustom",
      "onChangeCustom",
      "onFocusCustom",
      "parentId",
      "permissions",
      "propertyName",
      "readOnly",
      "settingsValidationErrors",
      "size",
      "style",
      "stylingBox",
      "subscribedEventNames",
      "type",
      "validate"
    ],
    "unresolvedExtends": [
      "IButtonItem",
      "IHasVersion"
    ]
  },
  "settingsForm": {
    "source": "button/settingsForm.ts",
    "mechanism": "fluent-builder",
    "parseQuality": "full"
  },
  "hasStandardAppearance": true,
  "appearanceFieldPaths": [
    "style",
    "size",
    "width",
    "height",
    "backgroundColor",
    "fontSize",
    "fontWeight",
    "borderColor",
    "borderRadius"
  ],
  "settingsFields": [
    {
      "path": "componentName",
      "label": "Component name",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "label",
      "label": "Label",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "tooltip",
      "label": "Tooltip",
      "editorType": "textArea",
      "group": "Display"
    },
    {
      "path": "icon",
      "label": "Icon",
      "editorType": "iconPicker",
      "group": "Display"
    },
    {
      "path": "iconPosition",
      "label": "Icon Position",
      "editorType": "dropdown",
      "group": "Display"
    },
    {
      "path": "buttonType",
      "label": "Button Type",
      "editorType": "dropdown",
      "group": "Display"
    },
    {
      "path": "danger",
      "label": "Danger",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "block",
      "label": "Block",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "hidden",
      "label": "Hidden",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "editMode",
      "label": "Edit mode",
      "editorType": "editModeSelector",
      "group": "Display"
    },
    {
      "path": "actionConfiguration",
      "label": "Action configuration",
      "editorType": "configurableActionConfigurator",
      "group": "Display"
    },
    {
      "path": "color",
      "label": "Color",
      "editorType": "colorPicker",
      "group": "Style"
    },
    {
      "path": "borderWidth",
      "label": "Border Width",
      "editorType": "textField",
      "group": "Style"
    },
    {
      "path": "borderStyle",
      "label": "Border Style",
      "editorType": "dropdown",
      "group": "Style"
    },
    {
      "path": "permissions",
      "label": "Permissions",
      "editorType": "permissionAutocomplete",
      "group": "Security"
    }
  ],
  "slots": {
    "hostsChildren": false,
    "customContainerNames": null,
    "detectedSlotKeys": [],
    "usesComponentsContainer": false
  },
  "sourceFiles": [
    "button/button.tsx",
    "button/interfaces.ts"
  ]
}
