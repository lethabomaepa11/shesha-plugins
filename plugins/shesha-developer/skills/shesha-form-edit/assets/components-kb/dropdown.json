{
  "type": "dropdown",
  "name": "Dropdown",
  "isInput": true,
  "isOutput": true,
  "canBeJsSetting": true,
  "icon": "DownSquareOutlined",
  "version": 7,
  "initModel": null,
  "settingsProps": {
    "interfaceName": "IDropdownComponentProps",
    "interfaceFile": "designer-components/dropdown/model.ts",
    "ownProps": [],
    "extends": [
      "Omit<IDropdownProps",
      "'style'>",
      "IConfigurableFormComponent"
    ],
    "resolvedProps": [
      "componentName",
      "context",
      "customEnabled",
      "customVisibility",
      "defaultValue",
      "description",
      "editMode",
      "hidden",
      "hideLabel",
      "id",
      "initialContext",
      "injectedDefaultValue",
      "injectedTableRow",
      "isDynamic",
      "jsSetting",
      "label",
      "labelAlign",
      "noDataIcon",
      "noDataSecondaryText",
      "noDataText",
      "onBlurCustom",
      "onChangeCustom",
      "onFocusCustom",
      "parentId",
      "permissions",
      "propertyName",
      "readOnly",
      "settingsValidationErrors",
      "size",
      "style",
      "stylingBox",
      "subscribedEventNames",
      "type",
      "validate"
    ],
    "unresolvedExtends": [
      "'style'>",
      "IHasVersion",
      "Omit<IDropdownProps"
    ]
  },
  "settingsForm": {
    "source": "dropdown/settingsForm.json",
    "mechanism": "json-markup",
    "parseQuality": "full"
  },
  "hasStandardAppearance": false,
  "appearanceFieldPaths": [
    "hideBorder",
    "style",
    "size"
  ],
  "settingsFields": [
    {
      "path": "propertyName",
      "label": "Property name",
      "editorType": "contextPropertyAutocomplete",
      "group": "Display"
    },
    {
      "path": "label",
      "label": "Label",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "labelAlign",
      "label": "Label align",
      "editorType": "dropdown",
      "group": "Display"
    },
    {
      "path": "placeholder",
      "label": "Placeholder",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "description",
      "label": "Description",
      "editorType": "textArea",
      "group": "Display"
    },
    {
      "path": "hidden",
      "label": "Hidden",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "hideLabel",
      "label": "Hide Label",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "editMode",
      "label": "Edit mode",
      "editorType": "editModeSelector",
      "group": "Display"
    },
    {
      "path": "hideBorder",
      "label": "Hide border",
      "editorType": "checkbox",
      "group": "Display",
      "shared": true
    },
    {
      "path": "defaultValue",
      "label": "Default Value",
      "editorType": "numberField",
      "group": "Data",
      "description": "Enter default value of component. (formData, formMode, globalState) are exposed"
    },
    {
      "path": "mode",
      "label": "Mode",
      "editorType": "dropdown",
      "group": "Data"
    },
    {
      "path": "dataSourceType",
      "label": "DataSource type",
      "editorType": "dropdown",
      "group": "Data"
    },
    {
      "path": "referenceListId",
      "label": "Reference List",
      "editorType": "referenceListAutocomplete",
      "group": "Data"
    },
    {
      "path": "filter",
      "label": "Items Filter",
      "editorType": "queryBuilder",
      "group": "Data"
    },
    {
      "path": "valueFormat",
      "label": "Value format",
      "editorType": "dropdown",
      "defaultValue": "simple",
      "group": "Data"
    },
    {
      "path": "incomeCustomJs",
      "label": "Key value",
      "editorType": "codeEditor",
      "group": "Data",
      "description": "Return key from the value"
    },
    {
      "path": "outcomeCustomJs",
      "label": "Custom value",
      "editorType": "codeEditor",
      "group": "Data",
      "description": "Return value that will be stored as field value"
    },
    {
      "path": "labelCustomJs",
      "label": "Item custom label",
      "editorType": "codeEditor",
      "group": "Data",
      "description": "Return label value"
    },
    {
      "path": "disableItemValue",
      "label": "Disable item value",
      "editorType": "checkbox",
      "group": "Data",
      "description": "Disable reference list from selection"
    },
    {
      "path": "disabledValues",
      "label": "Disabled Values",
      "editorType": "textArea",
      "group": "Data",
      "description": "Pass an array of positive integers to disable specific values. For example: [1, 2, 3]."
    },
    {
      "path": "ignoredValues",
      "label": "Ignored Values",
      "editorType": "textArea",
      "group": "Data",
      "description": "Pass an array of positive integers to ignore specific values. For example: [1, 2, 3]."
    },
    {
      "path": "dataSourceUrl",
      "label": "Data Source Url",
      "editorType": "textField",
      "group": "Data"
    },
    {
      "path": "values",
      "label": "Values",
      "editorType": "labelValueEditor",
      "group": "Data"
    },
    {
      "path": "onChangeCustom",
      "label": "On Change",
      "editorType": "codeEditor",
      "group": "Events",
      "description": "Enter custom eventhandler on changing of event. (form, value, option) are exposed"
    },
    {
      "path": "validate.required",
      "label": "Required",
      "editorType": "checkbox",
      "group": "Validation"
    },
    {
      "path": "style",
      "label": "Style",
      "editorType": "codeEditor",
      "group": "Style",
      "description": "A script that returns the style of the element as an object. This should conform to CSSProperties",
      "shared": true
    },
    {
      "path": "size",
      "label": "Size",
      "editorType": "dropdown",
      "group": "Style",
      "shared": true
    },
    {
      "path": "permissions",
      "label": "Permissions",
      "editorType": "permissionAutocomplete",
      "group": "Security"
    }
  ],
  "slots": {
    "hostsChildren": false,
    "customContainerNames": null,
    "detectedSlotKeys": [],
    "usesComponentsContainer": false
  },
  "sourceFiles": [
    "dropdown/index.tsx",
    "dropdown/model.ts"
  ]
}
