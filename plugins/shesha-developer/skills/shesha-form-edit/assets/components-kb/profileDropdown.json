      "group": "Display"
    },
    {
      "path": "hidden",
      "label": "Hidden",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "subText",
      "label": "Sub Text",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "subTextStyle",
      "label": "Sub Text Style",
      "editorType": "codeEditor",
      "group": "Style"
    },
    {
      "path": "subTextColor",
      "label": "Sub Text Color",
      "editorType": "colorPicker",
      "group": "Style"
    },
    {
      "path": "subTextFontSize",
      "label": "Sub Text Size",
      "editorType": "slider",
      "defaultValue": "12",
      "group": "Style"
    },
    {
      "path": "permissions",
      "label": "Permissions",
      "editorType": "permissionAutocomplete",
      "group": "Security"
    }
