{
  "type": "contextPropertyAutocomplete",
  "name": "Context Property Autocomplete",
  "isInput": true,
  "isOutput": true,
  "canBeJsSetting": null,
  "icon": "FileSearchOutlined",
  "version": 0,
  "initModel": null,
  "settingsProps": {
    "interfaceName": "IContextPropertyAutocompleteComponentProps",
    "interfaceFile": "designer-components/contextPropertyAutocomplete/index.tsx",
    "ownProps": [
      "dropdownStyle",
      "mode",
      "modelType",
      "autoFillProps"
    ],
    "extends": [
      "IConfigurableFormComponent"
    ],
    "resolvedProps": [
      "autoFillProps",
      "componentName",
      "context",
      "customEnabled",
      "customVisibility",
      "defaultValue",
      "description",
      "dropdownStyle",
      "editMode",
      "hidden",
      "hideLabel",
      "id",
      "initialContext",
      "injectedDefaultValue",
      "injectedTableRow",
      "isDynamic",
      "jsSetting",
      "label",
      "labelAlign",
      "mode",
      "modelType",
      "noDataIcon",
      "noDataSecondaryText",
      "noDataText",
      "onBlurCustom",
      "onChangeCustom",
      "onFocusCustom",
      "parentId",
      "permissions",
      "propertyName",
      "readOnly",
      "settingsValidationErrors",
      "size",
      "style",
      "stylingBox",
      "subscribedEventNames",
      "type",
      "validate"
    ],
    "unresolvedExtends": [
      "IHasVersion"
    ]
  },
  "settingsForm": {
    "source": "contextPropertyAutocomplete/settingsForm.json",
    "mechanism": "json-markup",
    "parseQuality": "full"
  },
  "hasStandardAppearance": false,
  "appearanceFieldPaths": [
    "hideBorder",
    "style",
    "size"
  ],
  "settingsFields": [
    {
      "path": "name",
      "label": "Name",
      "editorType": "propertyAutocomplete",
      "group": "Display"
    },
    {
      "path": "label",
      "label": "Label",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "labelAlign",
      "label": "Label align",
      "editorType": "dropdown",
      "group": "Display"
    },
    {
      "path": "placeholder",
      "label": "Placeholder",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "description",
      "label": "Description",
      "editorType": "textArea",
      "group": "Display"
    },
    {
      "path": "hidden",
      "label": "Hidden",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "hideLabel",
      "label": "Hide Label",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "hideBorder",
      "label": "Hide border",
      "editorType": "checkbox",
      "group": "Display",
      "shared": true
    },
    {
      "path": "modelType",
      "label": "Entity",
      "editorType": "textField",
      "group": "Data",
      "description": "Type of model. Leave empty to use default model type available in the current MetadataProvider"
    },
    {
      "path": "autoFillProps",
      "label": "Auto `Fill Props` label",
      "editorType": "checkbox",
      "group": "Data"
    },
    {
      "path": "validate.required",
      "label": "Required",
      "editorType": "checkbox",
      "group": "Validation"
    },
    {
      "path": "style",
      "label": "Style",
      "editorType": "codeEditor",
      "group": "Validation",
      "description": "A script that returns the style of the element as an object. This should conform to CSSProperties",
      "shared": true
    },
    {
      "path": "size",
      "label": "Size",
      "editorType": "dropdown",
      "group": "Validation",
      "shared": true
    },
    {
      "path": "permissions",
      "label": "Permissions",
      "editorType": "permissionAutocomplete",
      "group": "Security"
    }
  ],
  "slots": {
    "hostsChildren": false,
    "customContainerNames": null,
    "detectedSlotKeys": [],
    "usesComponentsContainer": false
  },
  "sourceFiles": [
    "contextPropertyAutocomplete/index.tsx"
  ]
}
