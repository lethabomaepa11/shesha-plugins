{
  "type": "alert",
  "name": "Alert",
  "isInput": false,
  "isOutput": null,
  "canBeJsSetting": null,
  "icon": "ExclamationCircleOutlined",
  "version": 2,
  "initModel": {
    "defaults": {
      "alertType": "info"
    },
    "raw": "(model) => ({\r\n    alertType: 'info',\r\n    ...model,\r\n  })"
  },
  "settingsProps": {
    "interfaceName": "IAlertComponentProps",
    "interfaceFile": "designer-components/alert/interfaces.ts",
    "ownProps": [
      "text",
      "description",
      "showIcon",
      "alertType",
      "closable",
      "icon"
    ],
    "extends": [
      "IConfigurableFormComponent"
    ],
    "resolvedProps": [
      "alertType",
      "closable",
      "componentName",
      "context",
      "customEnabled",
      "customVisibility",
      "defaultValue",
      "description",
      "editMode",
      "hidden",
      "hideLabel",
      "icon",
      "id",
      "initialContext",
      "injectedDefaultValue",
      "injectedTableRow",
      "isDynamic",
      "jsSetting",
      "label",
      "labelAlign",
      "noDataIcon",
      "noDataSecondaryText",
      "noDataText",
      "onBlurCustom",
      "onChangeCustom",
      "onFocusCustom",
      "parentId",
      "permissions",
      "propertyName",
      "readOnly",
      "settingsValidationErrors",
      "showIcon",
      "size",
      "style",
      "stylingBox",
      "subscribedEventNames",
      "text",
      "type",
      "validate"
    ],
    "unresolvedExtends": [
      "IHasVersion"
    ]
  },
  "settingsForm": {
    "source": "alert/settings.ts",
    "mechanism": "fluent-builder",
    "parseQuality": "full"
  },
  "hasStandardAppearance": false,
  "appearanceFieldPaths": [
    "style"
  ],
  "settingsFields": [
    {
      "path": "componentName",
      "label": "Component name",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "alertType",
      "label": "Type",
      "editorType": "dropdown",
      "defaultValue": "info",
      "group": "Display"
    },
    {
      "path": "text",
      "label": "Text",
      "editorType": "textArea",
      "description": "Accepts {{mustache}} syntax",
      "group": "Display"
    },
    {
      "path": "description",
      "label": "Description",
      "editorType": "textArea",
      "description": "Accepts {{mustache}} syntax",
      "group": "Display"
    },
    {
      "path": "showIcon",
      "label": "Show Icon",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "closable",
      "label": "Closable",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "icon",
      "label": "Icon",
      "editorType": "iconPicker",
      "group": "Display"
    },
    {
      "path": "hidden",
      "label": "Hidden",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "style",
      "label": "Style",
      "editorType": "codeEditor",
      "group": "Style",
      "shared": true
    },
    {
      "path": "permissions",
      "label": "Permissions",
      "editorType": "permissionAutocomplete",
      "group": "Security"
    }
  ],
  "slots": {
    "hostsChildren": false,
    "customContainerNames": null,
    "detectedSlotKeys": [],
    "usesComponentsContainer": false
  },
  "sourceFiles": [
    "alert/index.tsx",
    "alert/interfaces.ts"
  ]
}
