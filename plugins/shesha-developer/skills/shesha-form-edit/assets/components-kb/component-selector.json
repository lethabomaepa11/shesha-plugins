{
  "type": "component-selector",
  "name": "Component selector",
  "isInput": true,
  "isOutput": true,
  "canBeJsSetting": null,
  "icon": "BorderOutlined",
  "version": 2,
  "initModel": null,
  "settingsProps": {
    "interfaceName": "IComponentSelectorComponentProps",
    "interfaceFile": "designer-components/component-selector/interfaces.ts",
    "ownProps": [
      "componentType",
      "noSelectionItemText",
      "noSelectionItemValue",
      "propertyAccessor"
    ],
    "extends": [
      "IConfigurableFormComponent"
    ],
    "resolvedProps": [
      "componentName",
      "componentType",
      "context",
      "customEnabled",
      "customVisibility",
      "defaultValue",
      "description",
      "editMode",
      "hidden",
      "hideLabel",
      "id",
      "initialContext",
      "injectedDefaultValue",
      "injectedTableRow",
      "isDynamic",
      "jsSetting",
      "label",
      "labelAlign",
      "noDataIcon",
      "noDataSecondaryText",
      "noDataText",
      "noSelectionItemText",
      "noSelectionItemValue",
      "onBlurCustom",
      "onChangeCustom",
      "onFocusCustom",
      "parentId",
      "permissions",
      "propertyAccessor",
      "propertyName",
      "readOnly",
      "settingsValidationErrors",
      "size",
      "style",
      "stylingBox",
      "subscribedEventNames",
      "type",
      "validate"
    ],
    "unresolvedExtends": [
      "IHasVersion"
    ]
  },
  "settingsForm": {
    "source": "component-selector/settingsForm.ts",
    "mechanism": "fluent-builder",
    "parseQuality": "full"
  },
  "hasStandardAppearance": false,
  "appearanceFieldPaths": [],
  "settingsFields": [
    {
      "path": "propertyName",
      "label": "Property name",
      "editorType": "propertyAutocomplete"
    },
    {
      "path": "label",
      "label": "Label",
      "editorType": "textField"
    },
    {
      "path": "description",
      "label": "Description",
      "editorType": "textArea"
    },
    {
      "path": "noSelectionItemText",
      "label": "No selection item text",
      "editorType": "textField"
    },
    {
      "path": "noSelectionItemValue",
      "label": "No selection item value",
      "editorType": "textField"
    },
    {
      "path": "componentType",
      "label": "Component type",
      "editorType": "dropdown"
    },
    {
      "path": "customVisibility",
      "label": "Custom Visibility",
      "editorType": "codeEditor",
      "description": "Enter custom visibility code.  You must return true to show the component. The global variable data is provided, and allows you to access the data of any form component, by using its API key."
    },
    {
      "path": "customEnabled",
      "label": "Custom Enabled",
      "editorType": "codeEditor",
      "description": "Enter custom enabled code.  You must return true to enable the component. The global variable data is provided, and allows you to access the data of any form component, by using its API key."
    },
    {
      "path": "permissions",
      "label": "Permissions",
      "editorType": "permissionAutocomplete"
    }
  ],
  "slots": {
    "hostsChildren": false,
    "customContainerNames": null,
    "detectedSlotKeys": [],
    "usesComponentsContainer": false
  },
  "sourceFiles": [
    "component-selector/component.tsx",
    "component-selector/interfaces.ts"
  ]
}
