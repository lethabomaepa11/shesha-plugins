{
  "type": "refListStatus",
  "name": "Reference list status",
  "isInput": false,
  "isOutput": true,
  "canBeJsSetting": null,
  "icon": "FileSearchOutlined",
  "version": 4,
  "initModel": {
    "defaults": null,
    "raw": "(model) => {\r\n    const customModel: IRefListStatusProps = {\r\n      ...model,\r\n      hideLabel: true\r\n    };\r\n    return customModel;\r\n  }"
  },
  "settingsProps": {
    "interfaceName": "IRefListStatusProps",
    "interfaceFile": "designer-components/refListStatus/models.ts",
    "ownProps": [
      "referenceListId",
      "showIcon",
      "solidBackground",
      "showReflistName"
    ],
    "extends": [
      "IConfigurableFormComponent",
      "Omit<IFormItem",
      "'name'>"
    ],
    "resolvedProps": [
      "componentName",
      "context",
      "customEnabled",
      "customVisibility",
      "defaultValue",
      "description",
      "editMode",
      "hidden",
      "hideLabel",
      "id",
      "initialContext",
      "injectedDefaultValue",
      "injectedTableRow",
      "isDynamic",
      "jsSetting",
      "label",
      "labelAlign",
      "noDataIcon",
      "noDataSecondaryText",
      "noDataText",
      "onBlurCustom",
      "onChangeCustom",
      "onFocusCustom",
      "parentId",
      "permissions",
      "propertyName",
      "readOnly",
      "referenceListId",
      "settingsValidationErrors",
      "showIcon",
      "showReflistName",
      "size",
      "solidBackground",
      "style",
      "stylingBox",
      "subscribedEventNames",
      "type",
      "validate"
    ],
    "unresolvedExtends": [
      "'name'>",
      "IHasVersion",
      "Omit<IFormItem"
    ]
  },
  "settingsForm": {
    "source": "refListStatus/settings.ts",
    "mechanism": "fluent-builder",
    "parseQuality": "full"
  },
  "hasStandardAppearance": false,
  "appearanceFieldPaths": [
    "style"
  ],
  "settingsFields": [
    {
      "path": "propertyName",
      "label": "Property name",
      "editorType": "contextPropertyAutocomplete",
      "group": "Display"
    },
    {
      "path": "label",
      "label": "Label",
      "editorType": "textField",
      "group": "Display"
    },
    {
      "path": "labelAlign",
      "label": "Label align",
      "editorType": "dropdown",
      "group": "Display"
    },
    {
      "path": "description",
      "label": "Description",
      "editorType": "textArea",
      "group": "Display"
    },
    {
      "path": "hidden",
      "label": "Hidden",
      "editorType": "checkbox",
      "group": "Display"
    },
    {
      "path": "hideLabel",
      "label": "Hide Label",
      "editorType": "checkbox",
      "defaultValue": true,
      "group": "Display"
    },
    {
      "path": "showReflistName",
      "label": "Show Reflist Item Name",
      "editorType": "checkbox",
      "defaultValue": true,
      "description": "When checked the DisplayName/RefList Name will be shown.",
      "group": "Customize Status"
    },
    {
      "path": "showIcon",
      "label": "Show Icon",
      "editorType": "checkbox",
      "description": "When checked the icon will display on the left side of the DisplayName",
      "group": "Customize Status"
    },
    {
      "path": "solidBackground",
      "label": "Show Solid Background",
      "editorType": "checkbox",
      "defaultValue": true,
      "description": "When checked the component will show a coloured badge and display within it in white font the icon and/or the selected reference list item label.",
      "group": "Customize Status"
    },
    {
      "path": "style",
      "label": "Style",
      "editorType": "codeEditor",
      "description": "A script that returns the style of the element as an object. This should conform to CSSProperties",
      "group": "Style",
      "shared": true
    },
    {
      "path": "referenceListId",
      "label": "Reference list",
      "editorType": "refListAutocomplete",
      "group": "RefList Source"
    },
    {
      "path": "permissions",
      "label": "Permissions",
      "editorType": "permissionAutocomplete",
      "group": "Security"
    }
  ],
  "slots": {
    "hostsChildren": false,
    "customContainerNames": null,
    "detectedSlotKeys": [],
    "usesComponentsContainer": false
  },
  "sourceFiles": [
    "refListStatus/index.tsx",
    "refListStatus/models.ts"
  ]
}
