{
  "type": "endpointsAutocomplete",
  "name": "API Endpoints Autocomplete",
  "isInput": true,
  "isOutput": true,
  "canBeJsSetting": true,
  "icon": "ApiOutlined",
  "version": 3,
  "initModel": null,
  "settingsProps": {
    "interfaceName": "IEndpointsAutocompleteComponentProps",
    "interfaceFile": "designer-components/endpointsAutocomplete/interfaces.ts",
    "ownProps": [
      "httpVerb",
      "availableHttpVerbs",
      "mode"
    ],
    "extends": [
      "IConfigurableFormComponent"
    ],
    "resolvedProps": [
      "availableHttpVerbs",
      "componentName",
      "context",
      "customEnabled",
      "customVisibility",
      "defaultValue",
      "description",
      "editMode",
      "hidden",
      "hideLabel",
      "httpVerb",
      "id",
      "initialContext",
      "injectedDefaultValue",
      "injectedTableRow",
      "isDynamic",
      "jsSetting",
      "label",
      "labelAlign",
      "mode",
      "noDataIcon",
      "noDataSecondaryText",
      "noDataText",
      "onBlurCustom",
      "onChangeCustom",
      "onFocusCustom",
      "parentId",
      "permissions",
      "propertyName",
      "readOnly",
      "settingsValidationErrors",
      "size",
      "style",
      "stylingBox",
      "subscribedEventNames",
      "type",
      "validate"
    ],
    "unresolvedExtends": [
      "IHasVersion"
    ]
  },
  "settingsForm": {
    "source": "endpointsAutocomplete/settingsForm.json",
    "mechanism": "json-markup",
    "parseQuality": "full"
  },
  "hasStandardAppearance": false,
  "appearanceFieldPaths": [
    "hideBorder",
    "style",
    "size"
  ],
  "settingsFields": [
    {
      "path": "propertyName",
      "label": "Property name",
      "editorType": "contextPropertyAutocomplete"
    },
    {
      "path": "label",
      "label": "Label",
      "editorType": "textField"
    },
    {
      "path": "textType",
      "label": "Type",
      "editorType": "dropdown"
    },
    {
      "path": "labelAlign",
      "label": "Label align",
      "editorType": "dropdown"
    },
    {
      "path": "placeholder",
      "label": "Placeholder",
      "editorType": "textField"
    },
    {
      "path": "description",
      "label": "Description",
      "editorType": "textArea"
    },
    {
      "path": "prefix",
      "label": "Prefix",
      "editorType": "textField"
    },
    {
      "path": "suffix",
      "label": "Suffix",
      "editorType": "textField"
    },
    {
      "path": "hidden",
      "label": "Hidden",
      "editorType": "checkbox"
    },
    {
      "path": "hideLabel",
      "label": "Hide Label",
      "editorType": "checkbox"
    },
    {
      "path": "editMode",
      "label": "Edit mode",
      "editorType": "editModeSelector"
    },
    {
      "path": "hideBorder",
      "label": "Hide border",
      "editorType": "checkbox",
      "shared": true
    },
    {
      "path": "mode",
      "label": "Mode",
      "editorType": "radio"
    },
    {
      "path": "httpVerb",
      "label": "Http Verb",
      "editorType": "textField",
      "description": "Is used to filter the autocomplete by http verb"
    },
    {
      "path": "availableHttpVerbs",
      "label": "Http Verbs",
      "editorType": "labelValueEditor"
    },
    {
      "path": "onChangeCustom",
      "label": "On Change",
      "editorType": "codeEditor",
      "description": "Enter custom event handler on changing of event. (form, event) are exposed"
    },
    {
      "path": "onFocusCustom",
      "label": "On Focus",
      "editorType": "codeEditor",
      "description": "Enter custom event handler on focus of event. (form, event) are exposed"
    },
    {
      "path": "onBlurCustom",
      "label": "On Blur",
      "editorType": "codeEditor",
      "description": "Enter custom event handler on blur of event. (form, event) are exposed"
    },
    {
      "path": "validate.required",
      "label": "Required",
      "editorType": "checkbox"
    },
    {
      "path": "validate.minLength",
      "label": "Min Length",
      "editorType": "numberField"
    },
    {
      "path": "validate.maxLength",
      "label": "Max Length",
      "editorType": "numberField"
    },
    {
      "path": "validate.message",
      "label": "Message",
      "editorType": "textField"
    },
    {
      "path": "validate.validator",
      "label": "Validator",
      "editorType": "codeEditor",
      "description": "Enter custom validator logic for form.item rules. Returns a Promise"
    },
    {
      "path": "style",
      "label": "Style",
      "editorType": "codeEditor",
      "description": "A script that returns the style of the element as an object. This should conform to CSSProperties",
      "shared": true
    },
    {
      "path": "size",
      "label": "Size",
      "editorType": "dropdown",
      "shared": true
    },
    {
      "path": "permissions",
      "label": "Permissions",
      "editorType": "permissionAutocomplete",
      "group": "Security"
    }
  ],
  "slots": {
    "hostsChildren": false,
    "customContainerNames": null,
    "detectedSlotKeys": [],
    "usesComponentsContainer": false
  },
  "sourceFiles": [
    "endpointsAutocomplete/endpointsAutocomplete.tsx",
    "endpointsAutocomplete/interfaces.ts"
  ]
}
