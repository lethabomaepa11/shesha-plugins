adius":{}},"dimensions":{"width":"100%","minHeight":"100vh"},"stylingBox":"{\"paddingTop\":\"32\",\"paddingBottom\":\"32\",\"paddingLeft\":\"24\",\"paddingRight\":\"24\"}","shadow":{}}}],"formSettings":{"_formFields":["layout","colon","labelCol.span","wrapperCol.span","modelType"],"layout":"vertical","colon":false,"labelCol":{"span":0},"wrapperCol":{"span":24},"access":3,"permissions":[],"version":1,"dataLoaderType":"none","dataSubmitterType":"none","onBeforeDataLoad":"    try {\n      const userName = (application.user?.name ?? \"\") + (application.user?.surname ? \" \" + application.user.surname : \"\");\n      const personId = application.user?.personId;\n      const baseDefaults = { userName: userName.trim() || (application.user?.userName ?? \"there\"), hasSubscription: false };\n      if (!personId) { form.setFieldsValue(baseDefaults); return; }\n      // Find member by Person id (Member extends Person, ids match)\n      const memberFilter = JSON.stringify({ \"==\": [{ var: \"id\" }, personId] });\n      let memberResp;\n      try {\n        memberResp = await http.get(\"/api/services/app/Member/GetAll\", { params: { Filter: memberFilter, MaxResultCount: 1 } });\n      } catch (e) { form.setFieldsValue(baseDefaults); return; }\n      const member = memberResp?.data?.result?.items?.[0];\n      const subId = member?.subscription?.id;\n      if (!subId) { form.setFieldsValue(baseDefaults); return; }\n      const subResp = await http.get(\"/api/services/app/Subscription/Get\", { params: { id: subId } });\n      const sub = subResp?.data?.result;\n      const tierId = sub?.tier?.id;\n      let tier = null;\n      if (tierId) {\n        const tierResp = await http.get(\"/api/services/app/Tier/Get\", { params: { id: tierId } });\n        tier = tierResp?.data?.result;\n      }\n      const isMonthly = sub?.billingPeriod === 1 || (sub?.billingPeriod && sub.billingPeriod.itemValue === 1);\n      const amountVal = isMonthly ? tier?.priceMonthly : tier?.priceAnnual;\n      const period = isMonthly ? \"month\" : \"year\";\n      const fmtMoney = (n) => (typeof n === \"number\") ? \"R \" + n.toLocaleString(\"en-ZA\", { minimumFractionDigits: 0, maximumFractionDigits: 0 }) : \"—\";\n      const fmtDate = (d) => d ? moment(d).format(\"DD MMM YYYY\") : \"—\";\n      const statusLabel = (sub?.status && (sub.status._displayName || sub.status.itemText)) || (sub?._statusDisplayName) || \"Active\";\n      form.setFieldsValue({\n        userName: baseDefaults.userName,\n        hasSubscription: true,\n        tierId: tierId,\n        tierName: tier?.name ?? \"Membership\",\n        tierBlurb: tier?.blurb ?? \"\",\n        amountText: amountVal != null ? (fmtMoney(amountVal) + \" / \" + period) : \"—\",\n        renewsAt: fmtDate(sub?.renewsAt),\n        startedAt: fmtDate(sub?.startedAt),\n        statusLabel: statusLabel\n      });\n    } catch (err) {\n      message.error(err?.response?.data?.error?.message ?? \"Failed to load dashboard data\");\n      form.setFieldsValue({ userName: application.user?.name ?? \"there\", hasSubscription: false });\n    }","dataSubmittersSettings":{"gql":{"endpointType":"default"}},"dataLoadersSettings":{"gql":{"endpointType":"default"},"custom":{}}}}