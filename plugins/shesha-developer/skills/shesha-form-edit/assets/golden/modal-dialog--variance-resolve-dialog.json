                    "id": "0ae37dd2-e621-43bb-9987-068512011f76",
                    "itemType": "item",
                    "itemSubType": "button",
                    "sortOrder": 0,
                    "name": "btnCancel",
                    "label": "Cancel",
                    "buttonType": "default",
                    "icon": "CloseOutlined",
                    "buttonAction": "executeScript",
                    "actionConfiguration": {
                      "_type": "action-config",
                      "actionName": "Close Dialog",
                      "actionOwner": "shesha.common",
