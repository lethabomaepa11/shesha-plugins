                  {
                    "id": "e4ffcbec-d24a-4b7b-b4fa-2891a6d38902",
                    "itemType": "item",
                    "itemSubType": "button",
                    "sortOrder": 1,
                    "name": "btnResolve",
                    "label": "Resolve",
                    "buttonType": "primary",
                    "icon": "CheckOutlined",
                    "buttonAction": "executeScript",
                    "actionConfiguration": {
                      "_type": "action-config",
                      "actionName": "Execute Script",
                      "actionOwner": "shesha.common",
                      "version": 2,
                      "actionArguments": {
                        "expression": "var refId=function(x){return x?(x.id||x):null;};\nvar vt=data.varianceType;\nvar dispo = vt===2?data.dispoLocation : (vt===3?data.dispoCustodian : (vt===4?data.dispoCondition : data.dispoNotFound));\nif(!dispo){message.error('Please select a disposition.');throw new Error('disposition required');}\nif(!data.resolutionReason){message.error('Reason is required.');throw new Error('reason required');}\nvar assetId=refId(data.asset);\nvar campId=refId(data.campaign);\nvar me=application.user.personId;\nvar a=data.asset||{};\ntry{\n  if(vt===1 && dispo==='Located on recount'){\n    var nl=refId(data.foundLocation);\n    if(nl){ await http.put('/api/dynamic/Shesha.AssetManagement/RegisteredAsset/Crud/Update',{id:assetId,location:nl}); }\n  } else if(vt===1 && dispo==='Mark Lost/Stolen - write-off (finance)'){\n    await http.put('/api/dynamic/Shesha.AssetManagement/RegisteredAsset/Crud/Update',{id:assetId,lifecycleState:12});\n  } else if(vt===2 && dispo==='Correct Register'){\n    /* Register stands: reject the verifier's proposed location change; no asset update. */\n  } else if(vt===2 && dispo==='Initiate Formal transfer'){\n    var loc2=refId(data.targetLocation)||(a.observedLocation?refId(a.observedLocation):null);\n    if(!loc2){message.error('Select the destination location.');throw new Error('loc');}\n    await http.post('/api/services/AssetManagement/Transfer/InitiateTransfer',{assetId:assetId,transferType:3,toLocationId:loc2,toCustodianId:refId(data.newCustodian),toCostCentreId:refId(data.toCostCentre),reason:data.resolutionReason,requestedById:me});\n  } else if(vt===3 && dispo==='Correct custodian (write history)'){\n    var obsCust=(data.fieldObservation && data.fieldObservation.observedCustodian)?refId(data.fieldObservation.observedCustodian):null;\n    if(obsCust){ var eaId=a.enterpriseAsset?refId(a.enterpriseAsset):null; if(eaId){ await http.put('/api/dynamic/Shesha.Enterprise/Asset/Crud/Update',{id:eaId,responsiblePerson:obsCust}); } }\n    /* no field-observed custodian captured as a linked person: resolution recorded (audited), no FK change. */\n  } else if(vt===3 && dispo==='Initiate Formal transfer'){\n    var cust2=refId(data.newCustodian);\n    if(!cust2){message.error('Select the new custodian.');throw new Error('cust');}\n    var curLoc=a.location?refId(a.location):null;\n    await http.post('/api/services/AssetManagement/Transfer/InitiateTransfer',{assetId:assetId,transferType:1,toCustodianId:cust2,toLocationId:curLoc,toCostCentreId:refId(data.toCostCentre),reason:data.resolutionReason,requestedById:me});\n  } else if(vt===4 && (dispo==='Update condition only' || dispo==='Update condition only + raise maintenance')){\n    var cond=(data.newCondition===''||data.newCondition==null)?(a.observedCondition?a.observedCondition:null):data.newCondition;\n    if(cond==null||cond===0){message.error('Select the observed condition.');throw new Error('cond');}\n    await http.put('/api/dynamic/Shesha.AssetManagement/RegisteredAsset/Crud/Update',{id:assetId,conditionCode:cond});\n  } else if(vt===4 && dispo==='Flag for disposal'){\n    var method=(data.disposalMethod===''||data.disposalMethod==null)?7:data.disposalMethod;\n    await http.post('/api/services/AssetManagement/Disposal/Nominate',{assetId:assetId,reason:data.resolutionReason,method:method});\n  }\n}catch(e){message.error('The correction could not be applied: '+((e&&e.message)?e.message:'error'));throw e;}\nvar fin=!!data.financiallySignificant;\nif(vt===4 && dispo==='Flag impairment (finance)') fin=true;\nif(vt===1 && dispo==='Mark Lost/Stolen - write-off (finance)') fin=true;\nvar payload={id:data.id,campaign:campId,varianceType:vt,financiallySignificant:fin,resolved:true,resolutionDisposition:dispo,resolutionReason:data.resolutionReason,resolvedBy:me,resolvedDate:new Date().toISOString()};\nif(data.resolutionAuthority) payload.resolutionAuthority=data.resolutionAuthority;\nif(data.asset) payload.asset=assetId;\ntry{await http.put('/api/dynamic/Shesha.AssetManagement/Variance/Crud/Update',payload);}catch(e){message.error('The action was applied but saving the resolution failed. Please retry.');throw e;}\nmessage.success('Variance resolved.');"
                      },
                      "handleSuccess": true,
                      "onSuccess": {
                        "_type": "action-config",
                        "actionName": "Close Dialog",
                        "actionOwner": "shesha.common",
                        "version": 2,
                        "actionArguments": {
                          "showDialogResult": "true"
                        }
                      }
                    }
                  }
                ]
              }
            ],
            "parentId": "c6e45597-67ca-477a-b354-8dacb3644944"
