        "parentId": "root"
      }
    ],
    "formSettings": {
      "modelType": "Shesha.AssetManagement.Domain.Variances.Variance",
      "dataLoaderType": "none",
      "dataSubmitType": "none",
      "dataSubmitterType": "none",
      "layout": {
        "labelCol": {
          "span": 24
        },
        "wrapperCol": {
          "span": 24
        }
      },
      "labelCol": {
        "span": 24
      },
      "wrapperCol": {
        "span": 24
      },
      "access": null,
      "permissions": null,
      "version": 6,
      "onBeforeDataLoad": "form.setFieldsValue({...form.formArguments});",
      "onAfterDataLoad": "const run = async () => {\n  try {\n    var vid = data && data.id ? data.id : null;\n    if (!vid) return;\n    var props = 'id,detail,observedValue,custodianName,varianceType,financiallySignificant,resolved,resolutionDisposition,resolutionReason,resolutionAuthority,campaign{id},fieldObservation{id,observedLocation{id,_displayName},observedCondition,observedCustodian{id,_displayName}},asset{id,location{id,_displayName},observedLocation{id,_displayName},conditionCode,observedCondition,enterpriseAsset{id,responsiblePerson{id,_displayName}}}';\n    var res = await http.get('/api/dynamic/Shesha.AssetManagement/Variance/Crud/Get?id=' + vid + '&properties=' + encodeURIComponent(props));\n    var v = res && res.data && res.data.result;\n    if (v && form && form.setFieldsValue) form.setFieldsValue(v);\n    if (v && v.resolutionDisposition) {\n      var dispo = {};\n      if (v.varianceType === 1) dispo.dispoNotFound = v.resolutionDisposition;\n      else if (v.varianceType === 2) dispo.dispoLocation = v.resolutionDisposition;\n      else if (v.varianceType === 3) dispo.dispoCustodian = v.resolutionDisposition;\n      else if (v.varianceType === 4) dispo.dispoCondition = v.resolutionDisposition;\n      if (Object.keys(dispo).length) form.setFieldsValue(dispo);\n    }\n    if (v && !v.resolutionAuthority) form.setFieldsValue({ resolutionAuthority: null });\n    // Prefill the resolution inputs with the values the verifier submitted, so the reconciler\n    // only confirms or overrides them. Field-app capture (fieldObservation) is the primary source;\n    // the asset's pending-sign-off fields / the captured name string are the fallback.\n    if (v) {\n      var fo = v.fieldObservation || {};\n      var a = v.asset || {};\n      var patch = {};\n      var obsLoc = fo.observedLocation || a.observedLocation;\n      if (obsLoc) patch.targetLocation = obsLoc;\n      var obsCond = (fo.observedCondition != null && fo.observedCondition !== 0) ? fo.observedC