        { "name": "visible", "type": "boolean", "required": false, "desc": "Whether the layer is visible by default." },
        { "name": "dataSource", "type": "string", "required": true, "options": ["entity", "custom"], "desc": "'entity' fetches via entityType; 'custom' fetches via customUrl." },
